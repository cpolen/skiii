# Mapbox — required for map rendering
# IMPORTANT: This token is exposed client-side. Restrict it to your production
# domain(s) in the Mapbox dashboard: https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here

# Open-Meteo — set for paid customer endpoint (1M calls/day)
# Without this key, the free endpoint is used (10K calls/day)
OPEN_METEO_API_KEY=your_key_here

# Anthropic — optional, enables AI-enhanced guide messages
# Without this key, template-only messages are used (no degradation)
ANTHROPIC_API_KEY=
